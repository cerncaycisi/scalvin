{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "disableClaudeAiConnectors": true,
  "disableRemoteControl": true,
  "disableArtifact": true,
  "disableSkillShellExecution": true,
  "disableBundledSkills": true,
  "disableWorkflows": true,
  "autoMemoryEnabled": false,
  "enableAllProjectMcpServers": false,
  "enabledMcpjsonServers": [
    "scalvin"
  ],
  "permissions": {
    "allow": [
      "Read(/.therapy/safety-protocol.md)",
      "Read(/.therapy/commands.md)",
      "Read(/.therapy/runtime/**)",
      "Read(/.therapy/library/**)",
      "Read(/.therapy/persona.md)",
      "Read(/.therapy/session-structure.md)",
      "Read(/.therapy/modalities/**)",
      "Read(/START-SESSION.md)",
      "Read(/START-CLAUDE-SESSION.md)",
      "mcp__scalvin__capability_status",
      "mcp__scalvin__control_status",
      "mcp__scalvin__memory_show",
      "mcp__scalvin__source_status",
      "mcp__scalvin__source_proposals"
    ],
    "ask": [
      "mcp__scalvin__source_integrate",
      "mcp__scalvin__memory_control",
      "mcp__scalvin__memory_correct",
      "mcp__scalvin__memory_create",
      "mcp__scalvin__memory_add",
      "mcp__scalvin__backup_reminder",
      "mcp__scalvin__consent_set",
      "mcp__scalvin__session_manage"
    ],
    "deny": [
      "Read(/SETUP-NOTES.md)",
      "Read(/profile.md)",
      "Read(/ACTIVE-THEMES.md)",
      "Read(/CURRENT-FOCUS.md)",
      "Read(/NEXT-PRIMER.md)",
      "Read(/sessions/**)",
      "Read(/context/**)",
      "Read(/archive/**)",
      "Read(/sources/**)",
      "Read(/.therapy/user-overrides/**)",
      "Read(/.therapy/state/**)",
      "Read(/.therapy/change-control/**)",
      "Read(/.scalvin/**)",
      "Read(/.claude/**)",
      "Read(/.mcp.json)",
      "Read(/.codex/**)",
      "Edit(/SETUP-NOTES.md)",
      "Edit(/profile.md)",
      "Edit(/ACTIVE-THEMES.md)",
      "Edit(/CURRENT-FOCUS.md)",
      "Edit(/NEXT-PRIMER.md)",
      "Edit(/sessions/**)",
      "Edit(/context/**)",
      "Edit(/archive/**)",
      "Edit(/sources/**)",
      "Edit(/.therapy/user-overrides/**)",
      "Edit(/.therapy/state/**)",
      "Edit(/.therapy/change-control/**)",
      "Edit(/.scalvin/**)",
      "Edit(/.claude/**)",
      "Edit(/.mcp.json)",
      "Edit(/.codex/**)",
      "Write(/SETUP-NOTES.md)",
      "Write(/profile.md)",
      "Write(/ACTIVE-THEMES.md)",
      "Write(/CURRENT-FOCUS.md)",
      "Write(/NEXT-PRIMER.md)",
      "Write(/sessions/**)",
      "Write(/context/**)",
      "Write(/archive/**)",
      "Write(/sources/**)",
      "Write(/.therapy/user-overrides/**)",
      "Write(/.therapy/state/**)",
      "Write(/.therapy/change-control/**)",
      "Write(/.scalvin/**)",
      "Write(/.claude/**)",
      "Write(/.mcp.json)",
      "Write(/.codex/**)",
      "Edit(/.therapy/safety-protocol.md)",
      "Edit(/.therapy/commands.md)",
      "Edit(/.therapy/runtime/**)",
      "Edit(/.therapy/library/**)",
      "Edit(/.therapy/persona.md)",
      "Edit(/.therapy/session-structure.md)",
      "Edit(/.therapy/modalities/**)",
      "Edit(/START-SESSION.md)",
      "Edit(/START-CLAUDE-SESSION.md)",
      "Write(/.therapy/safety-protocol.md)",
      "Write(/.therapy/commands.md)",
      "Write(/.therapy/runtime/**)",
      "Write(/.therapy/library/**)",
      "Write(/.therapy/persona.md)",
      "Write(/.therapy/session-structure.md)",
      "Write(/.therapy/modalities/**)",
      "Write(/START-SESSION.md)",
      "Write(/START-CLAUDE-SESSION.md)",
      "Bash",
      "WebFetch",
      "WebSearch",
      "Agent",
      "Task",
      "Skill",
      "NotebookEdit"
    ],
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable",
    "disableAutoMode": "disable"
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": false,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "denyRead": [
        "."
      ],
      "allowRead": [
        "./.therapy/safety-protocol.md",
        "./.therapy/commands.md",
        "./.therapy/runtime",
        "./.therapy/library",
        "./.therapy/persona.md",
        "./.therapy/session-structure.md",
        "./.therapy/modalities",
        "./START-SESSION.md",
        "./START-CLAUDE-SESSION.md"
      ],
      "denyWrite": [
        "."
      ]
    },
    "network": {
      "allowedDomains": []
    }
  }
}
